modules = ["nodejs-22", "web"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_database:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["supabase-cli"]

[[ports]]
localPort = 8080
externalPort = 8080

[userenv]

[userenv.shared]
VITE_SUPABASE_URL = "https://butibupkkgiujnaoietc.supabase.co"
FRONTEND_URL = "https://30e7361d-3ae5-44c3-929d-93a04cbd4d06-00-2hmvsl6wuhwyb.pike.replit.dev"
ADMIN_USER_IDS = "a"
LOG_LEVEL = "info"
SUPABASE_URL = "https://butibupkkgiujnaoietc.supabase.co"
BASE_PATH = "/"
VITE_SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJ1dGlidXBra2dpdWpuYW9pZXRjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMyNDI5MDEsImV4cCI6MjA5ODgxODkwMX0.DcRaLjLcXa-hohmw9uiTEiEAFIAkbLr1Zs12SRNO1MM"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/markaz-fiqh && PORT=5000 BASE_PATH=/ pnpm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && PORT=8080 pnpm run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"
