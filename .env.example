# Supabase — backend database connection
# Found in: Supabase Dashboard → Project Settings → Database → Connection string (URI)
SUPABASE_DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Supabase — frontend client (public values, safe to expose)
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Backend auth — Supabase Admin (HANYA untuk backend, JANGAN pakai di frontend)
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Admin panel — comma-separated UUID Supabase user yang boleh akses /admin
ADMIN_USER_IDS=uuid-daru,uuid-admin-lain

# Mayar.id — payment gateway
# Found in: Mayar Dashboard → API / Developer / Integrasi
MAYAR_API_KEY=
MAYAR_WEBHOOK_SECRET=
# Produksi: https://api.mayar.id  |  Sandbox: https://api.mayar.club
MAYAR_BASE_URL=https://api.mayar.id

# URL frontend yang di-deploy (dipakai Edge Function untuk redirectUrl Mayar)
# Contoh: https://markaz-fiqih.vercel.app
FRONTEND_URL=

# Set ke 'false' di production untuk menonaktifkan endpoint simulate-success
# tanpa perlu deploy ulang. Biarkan kosong di development.
ALLOW_SIMULATE_SUCCESS=

# Runtime (set automatically by Replit workflows — do not set manually)
# PORT=5000          # frontend dev server
# BASE_PATH=/        # frontend base path
